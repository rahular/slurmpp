# ─── Required ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# ─── Slurm Connection ─────────────────────────────────────────────────────────
# "auto" probes REST first, falls back to CLI (squeue/sacct/etc on PATH)
# "rest" — slurmrestd HTTP API
# "cli"  — direct CLI commands (requires Slurm tools on PATH)
SLURM_INTERFACE=auto

# Only needed if SLURM_INTERFACE=rest
SLURM_REST_URL=http://localhost:6820
SLURM_REST_TOKEN=

# ─── Auth Backend ─────────────────────────────────────────────────────────────
# "local" — username/password stored in SQLite (default)
# "ldap"  — validate against LDAP directory
AUTH_BACKEND=local

# Only needed if AUTH_BACKEND=ldap
LDAP_URL=ldaps://ldap.example.edu
LDAP_BASE_DN=dc=example,dc=edu
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,{base_dn}
LDAP_ADMIN_GROUP_DN=cn=hpc-admins,ou=groups,dc=example,dc=edu

# ─── Optional ─────────────────────────────────────────────────────────────────
# Port for nginx (default: 80)
PORT=80

# Polling intervals (seconds)
POLL_JOBS_INTERVAL=15
POLL_NODES_INTERVAL=60
POLL_ACCOUNTING_INTERVAL=300

# Data retention
ANALYTICS_RETENTION_DAYS=90
OPERATIONAL_RETENTION_HOURS=24
